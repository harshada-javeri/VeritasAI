# Copy to `.env` and set the absolute path to the news-events feed.
# The application never hardcodes dataset paths; everything is driven from here.
DATASET_ROOT=/absolute/path/to/news-events-feed

# Optional overrides (defaults shown). Nested settings use a double-underscore.
# DATASET_RECURSIVE=true
# MODELS__HAIKU=claude-haiku-4-5-20251001
# MODELS__SONNET=claude-sonnet-4-6
# THRESHOLDS__CONFIDENCE_FLOOR=0.15
# COST__MONTHLY_BUDGET_USD=500
